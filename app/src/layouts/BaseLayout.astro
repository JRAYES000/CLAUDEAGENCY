---
import { Font } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Schema from '../components/Schema.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string; description: string; image?: string; imageAlt?: string;
  type?: 'website' | 'article'; noindex?: boolean;
  pageSchema?: Record<string, unknown>[];
}
const { title, description, image, imageAlt, type, noindex, pageSchema = [] } = Astro.props;
const site = Astro.site!.toString().replace(/\/$/, '');

const organization = {
  '@context': 'https://schema.org', '@type': 'Organization',
  '@id': `${site}/#organization`, name: 'Claude Agency', url: site,
  // logo en ImageObject = attendu par le rich result Article (publisher.logo).
  logo: { '@type': 'ImageObject', url: `${site}/logo.png`, width: 512, height: 512 },
  description: "Claude Agency aide les organismes de formation français à intégrer l'IA et automatiser leurs process.",
  areaServed: { '@type': 'Country', name: 'France' },
  email: 'contact@claudeagency.fr',
  foundingDate: '2026',
  // founder lié à l'entité Person (page auteur) → renforce le Knowledge Graph (E-E-A-T + GEO).
  founder: { '@type': 'Person', '@id': `${site}/a-propos/#julien-rayes`, name: 'Julien Rayes' },
  knowsAbout: [
    'Intelligence artificielle',
    'Automatisation des process',
    'Organismes de formation',
    'Qualiopi',
    'Référencement naturel (SEO)',
    'Google Ads (SEA)',
  ],
  // sameAs : profils réels existants (fondateur + page entreprise LinkedIn « Claude Agency »).
  sameAs: ['https://www.linkedin.com/in/julien-rayes/', 'https://www.linkedin.com/company/claudeagency-fr/'],
};
const website = {
  '@context': 'https://schema.org', '@type': 'WebSite',
  '@id': `${site}/#website`, url: site, name: 'Claude Agency',
  inLanguage: 'fr-FR', publisher: { '@id': `${site}/#organization` },
};
---
<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={title} description={description} image={image} imageAlt={imageAlt} type={type} noindex={noindex} />
    <Font cssVariable="--font-bricolage" preload />
    <Font cssVariable="--font-schibsted" preload />
    <script defer data-domain="claudeagency.fr" src="https://plausible.io/js/script.js"></script>
    <script is:inline>window.plausible=window.plausible||function(){(window.plausible.q=window.plausible.q||[]).push(arguments)}</script>
    <!-- Google tag (gtag.js) — Google Ads AW-18240137840 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18240137840"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-18240137840');
    </script>
    <!-- Instantly Website Visitors (Leadsy) -->
    <script id="vtag-ai-js" async src="https://r2.leadsy.ai/tag.js" data-pid="E9K4gB9DKK5wC4cn" data-version="062024" is:inline></script>
    <Schema schema={[organization, website, ...pageSchema]} />
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col font-sans">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-brand-500 focus:px-4 focus:py-2 focus:font-medium focus:text-cream-50">Aller au contenu</a>
    <Header />
    <main id="main" class="flex-1"><slot /></main>
    <Footer />
  </body>
</html>
