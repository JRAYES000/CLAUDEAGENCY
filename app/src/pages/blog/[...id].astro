---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AUTHOR, authorPerson } from '../../data/author';
import LeadMagnet from '../../components/LeadMagnet.astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true);
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const { title, description, pubDate, updatedDate, author, image, imageAlt, tags } = post.data;
const dateFmt = new Intl.DateTimeFormat('fr-FR', { dateStyle: 'long' });
const site = Astro.site!;

const allPosts = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true);
const related = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => ({ p, score: p.data.tags.filter((t) => tags.includes(t)).length }))
  .sort((a, b) => b.score - a.score || b.p.data.pubDate.valueOf() - a.p.data.pubDate.valueOf())
  .slice(0, 3)
  .map(({ p }) => p);

const articleSchema = {
  '@context': 'https://schema.org', '@type': 'BlogPosting',
  '@id': new URL(`/blog/${post.id}/#article`, site).href,
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(`/blog/${post.id}/`, site).href },
  headline: title, description,
  image: [new URL(image.src, site).href],
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@id': new URL('/a-propos/#julien-rayes', site).href },
  publisher: { '@id': new URL('/#organization', site).href },
  inLanguage: 'fr-FR',
  ...(tags.length ? { keywords: tags.join(', ') } : {}),
  ...(remarkPluginFrontmatter.wordCount ? { wordCount: remarkPluginFrontmatter.wordCount } : {}),
};
const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', site).href },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog/', site).href },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---
<BaseLayout title={title} description={description} type="article" image={image.src} pageSchema={[articleSchema, authorPerson(site), breadcrumb]}>
  <article class="mx-auto max-w-2xl px-4 py-16">
    <Image src={image} alt={imageAlt} width={1200} height={630} loading="eager" fetchpriority="high" class="rounded-xl" />
    <h1 class="mt-8 font-display text-4xl font-extrabold leading-[1.08] tracking-tight text-brand-700 sm:text-5xl">{title}</h1>
    <p class="mt-3 text-sm text-muted">
      Par {author} &middot;
      <time datetime={pubDate.toISOString()}>{dateFmt.format(pubDate)}</time>
      {updatedDate && <> &middot; Mis à jour le <time datetime={updatedDate.toISOString()}>{dateFmt.format(updatedDate)}</time></>}
      &middot; {remarkPluginFrontmatter.minutesRead}
    </p>
    {tags.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-2">{tags.map((t) => (
        <li><a href={`/blog/tags/${t.toLowerCase()}/`} class="rounded-full bg-brand-50 px-3 py-1 text-xs text-brand-700 hover:bg-brand-100">#{t}</a></li>
      ))}</ul>
    )}
    <div class="prose prose-stone mt-8 max-w-none"><Content /></div>

    <div class="mt-14">
      <LeadMagnet variant="compact" />
    </div>

    <aside class="mt-14 rounded-2xl border border-sand bg-cream-100 p-6 sm:p-7" aria-label="À propos de l'auteur">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-600">L'auteur</p>
      <p class="mt-2 font-display text-lg font-bold text-ink">{AUTHOR.name}</p>
      <p class="text-sm text-brand-600">{AUTHOR.jobTitle}</p>
      <p class="mt-3 text-sm leading-relaxed text-muted">{AUTHOR.bio}</p>
      <a href="/a-propos/" class="mt-3 inline-block text-sm font-semibold text-brand-700 hover:underline">En savoir plus sur Claude Agency <span aria-hidden="true">→</span></a>
    </aside>

    {related.length > 0 && (
      <section class="mt-14" aria-label="Articles liés">
        <h2 class="font-display text-2xl font-bold text-ink">À lire aussi</h2>
        <ul class="mt-5 divide-y divide-sand border-y border-sand">{related.map((p) => (
          <li>
            <a href={`/blog/${p.id}/`} class="group block py-5">
              <p class="font-display text-lg font-bold leading-snug text-ink transition-colors group-hover:text-brand-700">{p.data.title}</p>
              <p class="mt-1 line-clamp-2 text-sm text-muted">{p.data.description}</p>
            </a>
          </li>
        ))}</ul>
      </section>
    )}
  </article>
</BaseLayout>
