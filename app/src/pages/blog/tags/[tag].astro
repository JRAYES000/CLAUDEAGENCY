---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog', ({ data }) => import.meta.env.PROD ? !data.draft : true);
  // Slug d'URL en minuscules (URLs SEO-friendly) ; libellé d'affichage = casse d'origine.
  const bySlug = new Map(); // slug -> { label, posts }
  for (const p of posts) {
    for (const tag of p.data.tags) {
      const slug = tag.toLowerCase();
      if (!bySlug.has(slug)) bySlug.set(slug, { label: tag, posts: [] });
      bySlug.get(slug).posts.push(p);
    }
  }
  return [...bySlug.entries()].map(([slug, { label, posts: tagPosts }]) => ({
    params: { tag: slug },
    props: {
      tag: label,
      posts: tagPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}) satisfies GetStaticPaths;

const { tag, posts } = Astro.props;
---
<BaseLayout title={`Articles : ${tag}`} description={`Nos articles sur le thème « ${tag} » pour les organismes de formation.`} noindex>
  <section class="mx-auto max-w-3xl px-4 py-16">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-600">Thème</p>
    <h1 class="mt-3 font-display text-4xl font-extrabold leading-[1.05] tracking-tight text-ink sm:text-5xl">#{tag}</h1>
    <ul class="mt-8 space-y-4">{posts.map((p) => (
      <li><a href={`/blog/${p.id}/`} class="block rounded-lg border border-sand bg-cream-50 p-4 hover:bg-cream-100">
        <span class="font-display text-lg font-bold text-ink">{p.data.title}</span>
        <span class="mt-1 block text-sm text-muted">{p.data.description}</span>
      </a></li>
    ))}</ul>
    <a href="/blog/" class="mt-8 inline-block text-sm font-semibold text-brand-600 hover:text-brand-700"><span aria-hidden="true">←</span> Tous les articles</a>
  </section>
</BaseLayout>
