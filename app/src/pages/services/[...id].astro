---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const getStaticPaths = (async () => {
  const services = await getCollection('services');
  return services.map((s) => ({ params: { id: s.id }, props: { service: s } }));
}) satisfies GetStaticPaths;

const { service } = Astro.props;
const { Content } = await render(service);
const d = service.data;
const site = Astro.site!;

const related = d.relatedTags.length
  ? (await getCollection('blog', ({ data }) => import.meta.env.PROD ? !data.draft : true))
      .filter((p) => p.data.tags.some((t) => d.relatedTags.includes(t)))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 3)
  : [];

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service',
  '@id': new URL(`/services/${service.id}/#service`, site).href,
  name: d.title, description: d.description, serviceType: d.title,
  provider: { '@id': new URL('/#organization', site).href },
  areaServed: [
    { '@type': 'Country', name: 'France' },
    { '@type': 'Country', name: 'Belgique' },
    { '@type': 'Country', name: 'Suisse' },
    { '@type': 'Country', name: 'Luxembourg' },
  ],
  audience: { '@type': 'BusinessAudience', name: 'Organismes de formation' },
};
const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', site).href },
    { '@type': 'ListItem', position: 2, name: 'Services', item: new URL('/services/', site).href },
    { '@type': 'ListItem', position: 3, name: d.title },
  ],
};
// FAQPage schema : activé si la page service contient des questions fréquentes.
const faqSchema = d.faq.length > 0 ? {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: d.faq.map(({ q, a }) => ({
    '@type': 'Question', name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
} : null;
const schema = [serviceSchema, breadcrumb, ...(faqSchema ? [faqSchema] : [])];
---
<BaseLayout title={d.title} description={d.description} pageSchema={schema}>
  <section class="mx-auto max-w-3xl px-4 py-16">
    <div class="cp-rise">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-600">Service</p>
      <h1 class="mt-3 font-display text-4xl font-extrabold leading-[1.05] tracking-tight text-ink sm:text-5xl">{d.title}</h1>
      <p class="mt-4 text-lg leading-relaxed text-muted">{d.tagline}</p>
    </div>

    <h2 class="mt-14 font-display text-2xl font-bold text-ink">Le problème</h2>
    <p class="mt-3 leading-relaxed">{d.problem}</p>

    <h2 class="mt-12 font-display text-2xl font-bold text-ink">Ce que nous faisons</h2>
    <ul class="mt-4 space-y-2">{d.deliverables.map((x) => <li class="flex gap-3"><span aria-hidden="true" class="text-brand-500">→</span>{x}</li>)}</ul>

    <h2 class="mt-12 font-display text-2xl font-bold text-ink">Bénéfices</h2>
    <ul class="mt-4 space-y-2">{d.benefits.map((x) => <li class="flex gap-3"><span aria-hidden="true" class="text-brand-500">✓</span>{x}</li>)}</ul>

    <h2 class="mt-12 font-display text-2xl font-bold text-ink">Comment ça se passe</h2>
    <ol class="mt-4 space-y-4">{d.process.map((p, i) => (
      <li class="flex gap-4"><span class="font-display text-2xl font-bold text-brand-300">{i + 1}</span><div><p class="font-display font-bold text-ink">{p.step}</p><p class="text-muted">{p.detail}</p></div></li>
    ))}</ol>

    <div class="prose prose-stone mt-12 max-w-none"><Content /></div>

    {d.faq.length > 0 && (
      <section class="mt-14">
        <h2 class="font-display text-2xl font-bold text-ink">Questions fréquentes</h2>
        <dl class="mt-6 divide-y divide-sand border-y border-sand">{d.faq.map((f) => (
          <div class="py-5"><dt class="font-display font-bold text-ink">{f.q}</dt><dd class="mt-2 text-muted">{f.a}</dd></div>
        ))}</dl>
      </section>
    )}

    {related.length > 0 && (
      <section class="mt-14">
        <h2 class="font-display text-2xl font-bold text-ink">Articles liés</h2>
        <ul class="mt-4 space-y-3">{related.map((p) => (
          <li><a href={`/blog/${p.id}/`} class="text-brand-700 hover:underline">{p.data.title}</a></li>
        ))}</ul>
      </section>
    )}
  </section>

  <!-- CTA final : bandeau terracotta plein -->
  <section class="mt-16 bg-brand-700">
    <div class="mx-auto max-w-4xl px-4 py-20 text-center">
      <h2 class="font-display text-3xl font-extrabold text-cream-50 sm:text-4xl">Prêt à passer à l'action ?</h2>
      <p class="mx-auto mt-4 max-w-xl text-brand-100">Un audit offert pour identifier vos priorités, sans engagement.</p>
      <a href="/contact/" class="mt-8 inline-block rounded-lg bg-cream-50 px-7 py-3 font-semibold text-brand-800 transition-colors hover:bg-white">Demander un audit offert</a>
    </div>
  </section>
</BaseLayout>
