---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = await getCollection('services');
const byOrder = (a, b) => a.data.order - b.data.order;
const groups = [
  {
    label: 'Marketing & acquisition',
    desc: "Attirer des candidats qualifiés et remplir vos sessions.",
    items: services.filter((s) => s.data.category === 'marketing').sort(byOrder),
  },
  {
    label: 'IA & automatisation des process',
    desc: "Récupérer du temps sur la pédagogie et l'administratif.",
    items: services.filter((s) => s.data.category !== 'marketing').sort(byOrder),
  },
];
const site = Astro.site!.toString().replace(/\/$/, '');

const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${site}/services/` },
  ],
};

const itemList = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: 'Services IA pour organismes de formation — Claude Agency',
  description: "Tout ce qu'un organisme de formation peut déléguer à une équipe IA.",
  itemListElement: [...services].sort(byOrder).map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: s.data.title,
    url: `${site}/services/${s.id}/`,
    description: s.data.tagline,
  })),
};
---
<BaseLayout
  title="Services IA pour organismes de formation"
  description="SEO, SEA, optimisation de site, audit IA, automatisation et outils sur mesure : tout ce qu'un organisme de formation peut déléguer à une équipe IA."
  pageSchema={[breadcrumb, itemList]}
>
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="cp-rise max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-600">Nos services</p>
      <h1 class="mt-5 font-display text-4xl font-extrabold leading-[1.05] tracking-tight text-ink sm:text-5xl">
        Tout ce que vous pouvez déléguer pour votre <span class="text-brand-600">organisme de formation</span>
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        Du marketing à l'administratif, nos quatre consultants prennent en charge ce qui vous fait perdre du temps — en moyenne 3 à 4× plus vite et moins cher qu'une agence, grâce à la maîtrise de Claude Code et Claude Cowork.
      </p>
    </div>

    {groups.map((g) => (
      <div class="mt-14">
        <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
          <h2 class="font-display text-2xl font-bold text-ink">{g.label}</h2>
          <p class="text-muted">{g.desc}</p>
        </div>
        <ul class="mt-6 border-t border-sand">
          {g.items.map((s) => (
            <li class="border-b border-sand">
              <a href={`/services/${s.id}/`} class="group grid items-baseline gap-1 py-7 sm:grid-cols-[1fr_auto] sm:gap-8">
                <div>
                  <h3 class="font-display text-xl font-bold text-ink transition-colors group-hover:text-brand-700">{s.data.title}</h3>
                  <p class="mt-1 text-muted">{s.data.tagline}</p>
                </div>
                <span aria-hidden="true" class="hidden self-center text-brand-500 transition-transform group-hover:translate-x-1 sm:inline">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>

  <!-- CTA final : bandeau terracotta plein -->
  <section class="bg-brand-700">
    <div class="mx-auto max-w-4xl px-4 py-20 text-center">
      <h2 class="font-display text-3xl font-extrabold text-cream-50 sm:text-4xl">Par où commencer ?</h2>
      <p class="mx-auto mt-4 max-w-xl text-brand-100">Un audit offert pour identifier vos priorités, sans engagement.</p>
      <a href="/contact/" class="mt-8 inline-block rounded-lg bg-cream-50 px-7 py-3 font-semibold text-brand-800 transition-colors hover:bg-white">Demander un audit offert</a>
    </div>
  </section>
</BaseLayout>