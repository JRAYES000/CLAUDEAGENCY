---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroImg from '../assets/hero.jpg';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const faq = [
  { q: "Travaillez-vous uniquement avec des organismes de formation ?", a: "Oui, c'est notre spécialité : nous connaissons vos contraintes (Qualiopi, pédagogie, administratif)." },
  { q: "Faut-il être à l'aise avec la technique ?", a: "Non. Nous prenons en charge la complexité technique et formons vos équipes en langage clair." },
  { q: "Comment démarrer ?", a: "Par un audit offert : on identifie ensemble vos opportunités prioritaires." },
];
const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const why = [
  { t: "Spécialistes des organismes de formation", d: "On connaît vos contraintes : Qualiopi, pédagogie, administratif. Pas de discours générique." },
  { t: "Orientés résultats", d: "Des gains de temps concrets et mesurables, pas des promesses en l'air." },
  { t: "Vos équipes autonomes", d: "On forme et on outille pour que vous gardiez la main, sans dépendance." },
];
---
<BaseLayout
  title="Claude Partners"
  description="Claude Partners aide les organismes de formation à intégrer l'IA et automatiser leurs process pour gagner en efficacité."
  pageSchema={[faqSchema]}
>
  <!-- Hero asymétrique -->
  <section class="relative overflow-hidden bg-cream-100">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 py-20 md:grid-cols-[1.1fr_0.9fr] md:py-28">
      <div class="cp-rise">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-600">Conseil IA · Organismes de formation</p>
        <h1 class="mt-5 font-display text-5xl font-extrabold leading-[1.02] tracking-tight text-ink sm:text-6xl lg:text-7xl">
          L'IA au service de votre <span class="text-brand-600">organisme de formation</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted">
          Du diagnostic aux outils sur mesure, on vous aide à intégrer l'IA et à automatiser vos process. Vous récupérez du temps, vous montez en qualité.
        </p>
        <div class="mt-9 flex flex-wrap gap-3">
          <a href="/contact/" class="rounded-lg bg-brand-500 px-6 py-3 font-semibold text-white transition-colors hover:bg-brand-600">Demander un audit offert</a>
          <a href="/services/" class="rounded-lg border border-sand bg-cream-50 px-6 py-3 font-semibold text-ink transition-colors hover:border-brand-300">Découvrir nos services</a>
        </div>
      </div>

      <div class="cp-rise-2">
        <Image
          src={heroImg}
          alt="Un formateur accompagne deux apprenants autour d'un ordinateur portable dans une salle de formation lumineuse"
          loading="eager"
          fetchpriority="high"
          sizes="(min-width: 768px) 42vw, 100vw"
          class="w-full rounded-2xl border border-sand object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Problème (éditorial, asymétrique) -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="grid gap-8 md:grid-cols-[0.8fr_1.2fr] md:gap-16">
      <h2 class="font-display text-3xl font-bold leading-tight text-ink sm:text-4xl">Vos équipes débordées, l'administratif chronophage</h2>
      <p class="text-lg leading-relaxed text-muted">
        Qualiopi, suivi des stagiaires, création de supports : ces tâches grignotent le temps pédagogique.
        Bien intégrée, l'IA vous rend ces heures, sans bouleverser votre organisation.
      </p>
    </div>
  </section>

  <!-- Services (liste éditoriale, pas de grille de cartes) -->
  <section class="bg-cream-100">
    <div class="mx-auto max-w-6xl px-4 py-20">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">Quatre façons de vous faire gagner du temps</h2>
        <a href="/services/" class="text-sm font-semibold text-brand-600 hover:text-brand-700">Tous les services <span aria-hidden="true">→</span></a>
      </div>
      <ul class="mt-10 border-t border-sand">
        {services.map((s, i) => (
          <li class="border-b border-sand">
            <a href={`/services/${s.id}/`} class="group grid items-baseline gap-1 py-7 sm:grid-cols-[auto_1fr_auto] sm:gap-8">
              <span class="font-display text-2xl font-bold tabular-nums text-brand-300">{`0${i + 1}`}</span>
              <div>
                <h3 class="font-display text-xl font-bold text-ink transition-colors group-hover:text-brand-700">{s.data.title}</h3>
                <p class="mt-1 text-muted">{s.data.tagline}</p>
              </div>
              <span aria-hidden="true" class="hidden self-center text-brand-500 transition-transform group-hover:translate-x-1 sm:inline">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Méthode (stepper, sans cartes) -->
  <section class="mx-auto max-w-5xl px-4 py-20">
    <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">Notre méthode, en trois temps</h2>
    <ol class="mt-12 grid gap-10 sm:grid-cols-3">
      <li><div class="font-display text-5xl font-extrabold text-brand-200">1</div><p class="mt-3 font-display text-lg font-bold">On diagnostique</p><p class="mt-1 text-muted">On identifie vos opportunités prioritaires et leur ROI.</p></li>
      <li><div class="font-display text-5xl font-extrabold text-brand-200">2</div><p class="mt-3 font-display text-lg font-bold">On met en place</p><p class="mt-1 text-muted">On forme, on automatise, on outille, de bout en bout.</p></li>
      <li><div class="font-display text-5xl font-extrabold text-brand-200">3</div><p class="mt-3 font-display text-lg font-bold">On rend autonome</p><p class="mt-1 text-muted">Vos équipes gardent la main, sans dépendance à un prestataire.</p></li>
    </ol>
  </section>

  <!-- Pourquoi (blocs de texte, pas de cartes) -->
  <section class="bg-cream-100">
    <div class="mx-auto max-w-5xl px-4 py-20">
      <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">Pourquoi Claude Partners</h2>
      <div class="mt-10 grid gap-x-12 gap-y-8 sm:grid-cols-3">
        {why.map((w) => (
          <div>
            <h3 class="font-display text-lg font-bold text-brand-700">{w.t}</h3>
            <p class="mt-2 text-muted">{w.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-4 py-20">
    <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">Questions fréquentes</h2>
    <dl class="mt-8 divide-y divide-sand border-y border-sand">
      {faq.map((f) => (
        <div class="py-5">
          <dt class="font-display font-bold text-ink">{f.q}</dt>
          <dd class="mt-2 text-muted">{f.a}</dd>
        </div>
      ))}
    </dl>
  </section>

  <!-- CTA final : bandeau terracotta plein -->
  <section class="bg-brand-700">
    <div class="mx-auto max-w-4xl px-4 py-20 text-center">
      <h2 class="font-display text-3xl font-extrabold text-cream-50 sm:text-4xl">Faisons entrer l'IA dans votre organisme</h2>
      <p class="mx-auto mt-4 max-w-xl text-brand-100">Un audit offert pour identifier vos priorités, sans engagement.</p>
      <a href="/contact/" class="mt-8 inline-block rounded-lg bg-cream-50 px-7 py-3 font-semibold text-brand-800 transition-colors hover:bg-white">Demander un audit offert</a>
    </div>
  </section>
</BaseLayout>
