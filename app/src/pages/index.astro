---
import { getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroImg from '../assets/hero-pilotage-ia.jpg';
import surchargeImg from '../assets/dirigeant-surcharge.jpg';
import preuveImg from '../assets/resultats-automatisation.jpg';
import methodeImg from '../assets/methode-diagnostic.jpg';
import julienImg from '../assets/julien.jpg';
import TimeSavingsCalculator from '../components/TimeSavingsCalculator.astro';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

// Préchargement de l'image LCP (hero) : on génère les mêmes variantes que le composant
// <Image> ci-dessous (widths + format WebP) pour que le navigateur réutilise la ressource
// préchargée plutôt que d'en télécharger une seconde. Accélère le LCP mobile.
const heroSizes = '(min-width: 768px) 42vw, 100vw';
const heroOptimized = await getImage({
  src: heroImg,
  widths: [480, 800, 1200, 1600],
  sizes: heroSizes,
  format: 'webp',
});

// Récit de douleur : OF qui porte marketing + admin en plus de la pédagogie.
const irritants = [
  "Votre site ne remonte pas sur Google, faute de temps pour le SEO.",
  "Les agences SEO/SEA facturent cher — et ne connaissent pas votre métier.",
  "L'administratif et les audits Qualiopi grignotent vos soirées.",
  "L'IA, tout le monde en parle. Mais qui s'en occupe concrètement chez vous ?",
];

// L'équipe : 4 expertises qu'on délègue à Claude Agency (chaque carte renvoie vers sa page).
const expertises = [
  { t: "Référencement (SEO)", href: "/services/seo/", d: "On fait remonter votre organisme sur Google et on attire des candidats qualifiés, durablement." },
  { t: "Publicité (SEA)", href: "/services/sea/", d: "On pilote vos campagnes Google Ads pour remplir vos sessions, sans gaspiller votre budget." },
  { t: "Optimisation de site", href: "/services/optimisation-site/", d: "On transforme vos visiteurs en demandes d'inscription et de devis." },
  { t: "Process & admin OF", href: "/services/automatisation/", d: "Gestion administrative, dossiers de financement, audits de surveillance Qualiopi : on prépare, vous validez." },
];

// Preuve par l'exemple : résultats réels obtenus par notre fondateur dans son propre OF.
const proof = [
  { task: "Les relances administratives", detail: "Émargements, questionnaires de satisfaction, suivi des stagiaires jusqu'au bout de la formation.", before: "2 h / jour", after: "2 h / mois" },
  { task: "Les comptes rendus de visioconférence", detail: "Synthèses des réunions entre formateurs et clients, rédigées et classées automatiquement.", before: "2–3 h / semaine", after: "2–3 h / mois" },
  { task: "Le coaching des commerciaux", detail: "Un agent IA analyse chaque appel de closing et envoie au commercial des conseils personnalisés pour améliorer son taux de conversion.", before: "Surveillance manuelle", after: "Coaching auto après chaque appel" },
  { task: "La création de tunnels de vente", detail: "Pages, lead magnets et séquences d'e-mails générés en quelques minutes.", before: "5–6 h par tunnel", after: "Quelques minutes" },
];

// Profils d'OF : verticalisation (profondeur métier + SEO), formulé « ce qu'on prend en charge » (0 client → pas de claim de résultat passé).
const profils = [
  { t: "CFA / organisme multi-formations", reality: "Volume de dossiers, suivi de cohortes, reporting aux financeurs.", change: "Un suivi et un reporting en partie automatisés, des réponses normalisées." },
  { t: "OF indépendant / petite structure", reality: "Tout repose sur une ou deux personnes ; l'administratif grignote le temps pédagogique.", change: "Des heures récupérées chaque semaine sur l'admin récurrent — qu'on prend en charge." },
  { t: "Centre certifié Qualiopi", reality: "Tenir ses preuves toute l'année, et un audit de surveillance lourd (souvent une dizaine d'heures, 3 000 à 4 000 € s'il est externalisé).", change: "Une tenue des preuves allégée au fil de l'année. Nous ne sommes pas un cabinet d'audit Qualiopi : on vous fait gagner du temps sur la préparation." },
  { t: "Formateur indépendant", reality: "Création de supports, prospection, facturation — et vous êtes seul·e.", change: "Des supports produits plus vite, des relances et des devis assistés, votre marketing pris en main." },
];

const faq = [
  { q: "L'IA va-t-elle remplacer les formateurs ?", a: "Non. Elle enlève l'administratif et la production répétitive. La pédagogie, l'animation, la relation : ça reste vous — et c'est là qu'est votre valeur." },
  { q: "L'IA risque-t-elle de dénaturer mes contenus ?", a: "Non. On part de vos contenus, votre ligne, votre voix. L'IA accélère la première version ; vous gardez la main éditoriale sur le fond." },
  { q: "En vous déléguant tout, est-ce que je deviens dépendant ?", a: "Vous déléguez ce qui vous épuise — le marketing, l'admin — pas votre cœur de métier. Les outils et contenus produits vous appartiennent ; vous pouvez reprendre la main quand vous voulez." },
  { q: "Travaillez-vous uniquement avec des organismes de formation ?", a: "Oui, c'est notre spécialité — et notre métier : notre fondateur pilote le commercial et le marketing d'un organisme de formation, et nous en connaissons les contraintes (Qualiopi, financement, pédagogie) au quotidien." },
  { q: "Comment pouvez-vous être moins chers qu'une agence ?", a: "Nos consultants maîtrisent Claude Code et Claude Cowork. On produit le même travail en moyenne 3 à 4× moins de temps — et on répercute ce gain directement sur nos tarifs." },
  { q: "Combien ça coûte ? Quel budget prévoir ?", a: "L'audit de départ est offert et sans engagement. Ensuite, le devis dépend du périmètre : on propose ce qui a le meilleur retour sur le temps gagné, sans vendre l'inutile." },
  { q: "Faut-il être à l'aise avec la technique ?", a: "Non. On prend en charge toute la complexité technique et on vous parle en langage clair." },
  { q: "Faut-il changer nos outils actuels ?", a: "Non. L'IA et nos prestations se greffent sur votre stack existante — votre CRM, vos logiciels, vos tableurs. On s'adapte à vous." },
  { q: "Nos données et celles de nos stagiaires sont-elles en sécurité ?", a: "Oui. Nous privilégions des solutions conformes RGPD et hébergées dans l'UE. La confidentialité n'est jamais négociée." },
  { q: "L'IA est-elle compatible avec mes obligations Qualiopi ?", a: "Oui. L'IA aide surtout à tenir vos preuves et votre traçabilité au fil de l'année. Nous ne sommes pas un cabinet d'audit Qualiopi : nous vous faisons gagner du temps sur la préparation." },
  { q: "En combien de temps voit-on des résultats ?", a: "Les premières automatisations simples se mettent en place en quelques jours. Côté acquisition, la publicité agit vite, le référencement sur quelques mois. L'audit fixe les priorités pour des gains rapides dès le départ." },
  { q: "Je suis formateur indépendant, est-ce que c'est pour moi aussi ?", a: "Oui. Quand on travaille seul, le temps gagné sur l'administratif, les supports et la prospection compte double." },
  { q: "Quel type de reporting vais-je recevoir et à quelle fréquence ?", a: "Tous les jours, vous recevez un reporting de l'activité du consultant et des consultants assignés à votre projet : le nombre d'heures consacrées et le détail des tâches réalisées. Vous gardez ainsi une visibilité permanente sur ce qui est fait, et l'assurance que votre investissement est suivi de près." },
  { q: "Comment démarrer ?", a: "Par un audit offert : on identifie ensemble vos priorités et vous repartez avec une feuille de route chiffrée, avec ou sans nous." },
];
---
<BaseLayout
  title="Agence marketing IA pour organismes de formation | Claude Agency"
  description="Claude Agency, l'agence marketing qui pilote votre SEO, vos Google Ads et votre administratif Qualiopi avec Claude, l'IA d'Anthropic. Audit gratuit offert."
  imageAlt="Dirigeant d'un organisme de formation serein, accompagné par une équipe IA qui pilote son SEO, sa publicité et son administratif"
>
  <!-- Préchargement responsive de l'image LCP (hero) -->
  <link
    slot="head"
    rel="preload"
    as="image"
    type="image/webp"
    imagesrcset={heroOptimized.srcSet.attribute}
    imagesizes={heroSizes}
    fetchpriority="high"
  />

  <!-- Hero asymétrique -->
  <section class="relative overflow-hidden bg-cream-100">
    <div class="mx-auto grid max-w-6xl items-center gap-8 px-4 py-12 md:grid-cols-[1.1fr_0.9fr] md:py-16">
      <div class="cp-rise">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-600">Équipe IA · Organismes de formation</p>
        <h1 class="mt-3 font-display text-2xl font-extrabold leading-tight tracking-tight text-ink sm:text-3xl lg:text-4xl">
          L'agence IA qui gère le marketing et l'administratif de votre <span class="text-brand-600">organisme de formation</span>
        </h1>
        <p class="mt-4 max-w-xl text-lg leading-relaxed text-muted">
          SEO, SEA, optimisation de votre site, gestion administrative et audits Qualiopi : nos quatre consultants s'en chargent pour vous — en moyenne 3× plus vite et 3× moins cher qu'un prestataire traditionnel, grâce à notre totale maîtrise de Claude et outils IA.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/contact/" class="rounded-lg bg-brand-500 px-6 py-3 font-semibold text-white transition-colors hover:bg-brand-600">Demander un audit offert</a>
          <a href="/diagnostic/" class="rounded-lg border border-sand bg-cream-50 px-6 py-3 font-semibold text-ink transition-colors hover:border-brand-300">Diagnostic gratuit (2&nbsp;min)</a>
        </div>
        <p class="mt-5 flex items-center gap-2.5 text-sm text-muted">
          <span aria-hidden="true" class="h-1.5 w-1.5 shrink-0 rounded-full bg-brand-400"></span>
          Les méthodes qu'on déploie chez vous, on les a d'abord rôdées dans notre propre organisme — +3 M€ de CA à la clé.
        </p>
      </div>

      <!-- Pas d'animation cp-rise sur l'image : c'est l'élément LCP ; une entrée
           opacity:0 -> 1 retarderait l'horodatage LCP (surtout sur mobile). -->
      <div>
        <Image
          src={heroImg}
          alt="Dirigeant d'organisme de formation serein à son bureau, épaulé par une équipe d'agents IA qui pilotent son SEO, sa publicité, son site et son administratif"
          loading="eager"
          fetchpriority="high"
          widths={[480, 800, 1200, 1600]}
          sizes={heroSizes}
          class="w-full rounded-2xl border border-sand object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Problème (éditorial, asymétrique) -->
  <section class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-8 md:grid-cols-[0.85fr_1.15fr] md:gap-16">
      <div>
        <h2 class="font-display text-3xl font-bold leading-tight text-ink sm:text-4xl">Vous portez tout, en même temps</h2>
        <Image
          src={surchargeImg}
          alt="Directrice d'organisme de formation submergée par les dossiers, les relances et l'administratif à son bureau"
          sizes="(min-width: 768px) 38vw, 100vw"
          loading="lazy"
          class="mt-8 hidden w-full rounded-2xl border border-sand object-cover md:block"
        />
      </div>
      <div>
        <p class="text-lg leading-relaxed text-muted">
          Diriger un organisme de formation, c'est faire dix métiers à la fois : la pédagogie, le commercial,
          le marketing, l'administratif, la qualité. Les journées n'y suffisent pas — et tout ce qui touche
          au marketing ou à l'admin passe toujours après.
        </p>
        <ul class="mt-8 space-y-3">
          {irritants.map((i) => (
            <li class="flex gap-3 text-muted">
              <span aria-hidden="true" class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-300"></span>
              <span>{i}</span>
            </li>
          ))}
        </ul>
        <p class="mt-8 text-lg font-medium leading-relaxed text-ink">
          Et si vous déléguiez tout ça à une équipe qui va 3 à 4× plus vite, pour bien moins cher ?
        </p>
      </div>
    </div>
  </section>

  <!-- Déléguez à notre équipe : les 4 expertises -->
  <section id="expertises" class="bg-cream-100">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <div class="max-w-2xl">
        <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">Quatre experts. Une équipe. Un prix imbattable.</h2>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          Vous ne recrutez pas, vous ne formez personne : vous déléguez. Chacun de nos consultants couvre un domaine où les organismes de formation perdent du temps — ou de l'argent chez une agence.
        </p>
      </div>
      <ul class="mt-8 grid gap-px overflow-hidden rounded-2xl border border-sand bg-sand sm:grid-cols-2">
        {expertises.map((e) => (
          <li>
            <a href={e.href} class="group flex h-full flex-col bg-cream-50 p-7 transition-colors hover:bg-cream-100">
              <h3 class="flex items-center gap-2 font-display text-xl font-bold text-ink transition-colors group-hover:text-brand-700">
                {e.t}<span aria-hidden="true" class="text-brand-500 transition-transform group-hover:translate-x-1">→</span>
              </h3>
              <p class="mt-2 leading-relaxed text-muted">{e.d}</p>
            </a>
          </li>
        ))}
      </ul>
      <p class="mt-6 text-muted">
        Ces quatre expertises font de nous une <a href="/agence-marketing-claude/" class="font-semibold text-brand-700 hover:underline">agence marketing pilotée par Claude</a>, l'IA d'Anthropic — même travail qu'une agence classique, 3 à 4 fois plus vite.
      </p>
    </div>
  </section>

  <!-- Calculateur de temps gagné (signature interactive) -->
  <TimeSavingsCalculator />

  <!-- Preuve : résultats réels dans notre propre OF -->
  <section class="bg-cream-100">
    <div class="mx-auto max-w-5xl px-4 py-12">
    <div class="grid gap-8 md:grid-cols-[1fr_0.9fr] md:items-center md:gap-12">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-600">La preuve</p>
        <h2 class="mt-3 font-display text-3xl font-bold text-ink sm:text-4xl">On l'a d'abord fait dans notre propre organisme</h2>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          Avant d'en faire notre métier, notre fondateur a automatisé le back-office de son propre organisme de formation. Voici des résultats réels, mesurés — pas des promesses.
        </p>
      </div>
      <Image
        src={preuveImg}
        alt="Tableau de bord affichant des indicateurs en hausse et des tâches automatisées dans un organisme de formation"
        sizes="(min-width: 768px) 42vw, 100vw"
        loading="lazy"
        class="w-full rounded-2xl border border-sand object-cover"
      />
    </div>
    <ul class="mt-8 border-t border-sand">
      {proof.map((p) => (
        <li class="grid gap-3 border-b border-sand py-7 sm:grid-cols-[1.1fr_0.9fr] sm:items-center sm:gap-8">
          <div>
            <h3 class="font-display text-lg font-bold text-ink">{p.task}</h3>
            <p class="mt-1 leading-relaxed text-muted">{p.detail}</p>
          </div>
          <div class="text-sm sm:text-right">
            <p class="text-muted">Avant : {p.before}</p>
            <p class="mt-1 font-display text-base font-bold text-brand-700">Après : {p.after}</p>
          </div>
        </li>
      ))}
    </ul>
    <p class="mt-8 text-muted">Ces gains, nous les installons désormais chez les organismes de formation que nous accompagnons.</p>
    </div>
  </section>

  <!-- Nos prestations (liste éditoriale, pas de grille de cartes) -->
  <section class="mx-auto max-w-6xl px-4 py-12">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-2xl">
        <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">Nos prestations, de bout en bout</h2>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          Au-delà du marketing, on intègre l'IA dans tout votre organisme : on diagnostique, on automatise, on outille.
        </p>
      </div>
      <a href="/services/" class="text-sm font-semibold text-brand-600 hover:text-brand-700">Tous les services <span aria-hidden="true">→</span></a>
    </div>
    <ul class="mt-8 border-t border-sand">
      {services.filter((s) => s.data.category !== 'marketing').map((s) => (
        <li class="border-b border-sand">
          <a href={`/services/${s.id}/`} class="group grid items-baseline gap-1 py-7 sm:grid-cols-[1fr_auto] sm:gap-8">
            <div>
              <h3 class="font-display text-xl font-bold text-ink transition-colors group-hover:text-brand-700">{s.data.title}</h3>
              <p class="mt-1 text-muted">{s.data.tagline}</p>
            </div>
            <span aria-hidden="true" class="hidden self-center text-brand-500 transition-transform group-hover:translate-x-1 sm:inline">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Méthode (stepper, sans cartes) -->
  <section class="bg-cream-100">
    <div class="mx-auto max-w-5xl px-4 py-12">
      <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">Notre méthode, en trois temps</h2>
      <Image
        src={methodeImg}
        alt="Les trois temps de la méthode Claude Agency : diagnostic, prise en charge, reporting"
        sizes="(min-width: 1024px) 64rem, 100vw"
        loading="lazy"
        class="mt-8 w-full rounded-2xl border border-sand object-cover"
      />
      <ol class="mt-10 grid gap-10 sm:grid-cols-3">
        <li><div class="font-display text-5xl font-extrabold text-brand-200">1</div><p class="mt-3 font-display text-lg font-bold">On diagnostique</p><p class="mt-1 text-muted">On identifie vos priorités à plus fort ROI — marketing, admin, IA.</p></li>
        <li><div class="font-display text-5xl font-extrabold text-brand-200">2</div><p class="mt-3 font-display text-lg font-bold">On prend en charge</p><p class="mt-1 text-muted">On exécute de bout en bout : campagnes, automatisations, outils, dossiers.</p></li>
        <li><div class="font-display text-5xl font-extrabold text-brand-200">3</div><p class="mt-3 font-display text-lg font-bold">On rend compte</p><p class="mt-1 text-muted">Vous suivez les résultats en toute transparence, sans vous en occuper.</p></li>
      </ol>
    </div>
  </section>

  <!-- Profils d'OF (verticalisation — profondeur métier + SEO) -->
  <section class="mx-auto max-w-6xl px-4 py-12">
    <div class="max-w-2xl">
      <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">Quel organisme êtes-vous ?</h2>
      <p class="mt-4 text-lg leading-relaxed text-muted">On connaît vos contraintes. Voici ce qu'on peut prendre en charge, concrètement, selon votre structure.</p>
    </div>
    <div class="mt-8 grid gap-x-12 gap-y-10 sm:grid-cols-2">
      {profils.map((p) => (
        <div>
          <h3 class="font-display text-xl font-bold text-brand-700">{p.t}</h3>
          <p class="mt-2 text-muted"><span class="font-semibold text-ink">Votre réalité :</span> {p.reality}</p>
          <p class="mt-1 text-muted"><span class="font-semibold text-ink">Avec nous :</span> {p.change}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Le fondateur (incarnation humaine + portrait réel) -->
  <section class="bg-cream-100">
    <div class="mx-auto max-w-3xl px-4 py-12">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-600">Le fondateur</p>
    <div class="mt-6 grid gap-8 sm:grid-cols-[170px_1fr] sm:items-start sm:gap-10">
      <Image
        src={julienImg}
        alt="Portrait de Julien Rayes, fondateur de Claude Agency"
        width={340}
        height={340}
        sizes="(min-width: 640px) 170px, 160px"
        loading="lazy"
        class="w-40 rounded-2xl border border-sand object-cover sm:w-full"
      />
      <div>
        <blockquote class="border-l-2 border-brand-300 pl-6">
          <p class="font-display text-2xl font-bold leading-snug text-ink sm:text-3xl">
            « Je n'ai pas appris l'IA dans les livres. Je l'ai déployée, seul, dans un organisme de formation à plus de 3 M€ de chiffre d'affaires. »
          </p>
          <p class="mt-6 text-lg leading-relaxed text-muted">
            Directeur commercial et marketing, j'ai automatisé l'administratif, le commercial et le marketing avec Make et Claude Code. Claude Agency met cette expérience au service des autres organismes de formation — avec une équipe de quatre spécialistes.
          </p>
          <footer class="mt-6 font-display font-bold text-ink">
            Julien Rayes <span class="font-sans font-normal text-muted">— Fondateur, Claude Agency</span>
          </footer>
        </blockquote>
        <p class="mt-6 pl-6 text-sm">
          <a href="/a-propos/#julien-rayes" class="font-semibold text-brand-600 hover:text-brand-700">Découvrir notre histoire <span aria-hidden="true">→</span></a>
        </p>
      </div>
    </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-4 py-12">
    <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">Questions fréquentes</h2>
    <dl class="mt-8 divide-y divide-sand border-y border-sand">
      {faq.map((f) => (
        <div class="py-5">
          <dt class="font-display font-bold text-ink">{f.q}</dt>
          <dd class="mt-2 text-muted">{f.a}</dd>
        </div>
      ))}
    </dl>
  </section>

  <!-- CTA final : bandeau terracotta plein -->
  <section class="bg-brand-700">
    <div class="mx-auto max-w-4xl px-4 py-12 text-center">
      <h2 class="font-display text-3xl font-extrabold text-cream-50 sm:text-4xl">Déléguez ce qui vous freine. Gardez la pédagogie.</h2>
      <p class="mx-auto mt-4 max-w-xl leading-relaxed text-brand-100">
        Commencez par un audit offert : on identifie vos priorités à plus fort ROI — marketing, admin, IA — et on vous remet une feuille de route chiffrée. Vous repartez avec, que vous travailliez avec nous ensuite ou non.
      </p>
      <a href="/contact/" class="mt-8 inline-block rounded-lg bg-cream-50 px-7 py-3 font-semibold text-brand-800 transition-colors hover:bg-white">Demander un audit offert</a>
      <p class="mt-5 text-sm text-brand-100">Sans engagement · Vous repartez avec votre feuille de route.</p>
      <p class="mt-3 text-sm text-brand-100">Pas encore prêt pour un rendez-vous ? <a href="/diagnostic/" class="font-semibold text-cream-50 underline underline-offset-2 hover:text-white">Faites le diagnostic gratuit</a> — 2 minutes, réponse personnalisée.</p>
    </div>
  </section>
</BaseLayout>
