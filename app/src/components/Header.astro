---
const links = [
  { href: '/services/', label: 'Services' },
  { href: '/diagnostic/', label: 'Diagnostic gratuit' },
  { href: '/ressources/10-automatisations-ia/', label: 'Ressources' },
  { href: '/blog/', label: 'Blog' },
  { href: '/a-propos/', label: 'À propos' },
];
const path = Astro.url.pathname;
const isActive = (href) => path === href || path.startsWith(href);
---
<header class="border-b border-sand bg-cream-50">
  <nav aria-label="Navigation principale" class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
    <a href="/" class="flex items-center gap-2.5 text-ink">
      <svg aria-hidden="true" viewBox="0 0 200 200" class="h-8 w-8 shrink-0 text-brand-500" fill="currentColor"><path d="M100,20 L108.4,68 L100,87.2 L91.6,68 Z"/><path d="M124.8,57.05 L123.27,76.49 L106.4,88.91 L108.73,68.09 Z"/><path d="M159.58,65.6 L131.91,91.27 L111.09,93.6 L123.51,76.73 Z"/><path d="M149.6,100 L132,108.4 L112.8,100 L132,91.6 Z"/><path d="M169.28,140 L123.51,123.27 L111.09,106.4 L131.91,108.73 Z"/><path d="M124.8,142.95 L108.73,131.91 L106.4,111.09 L123.27,123.51 Z"/><path d="M100,173.6 L91.6,132 L100,112.8 L108.4,132 Z"/><path d="M75.2,142.95 L76.73,123.51 L93.6,111.09 L91.27,131.91 Z"/><path d="M30.72,140 L68.09,108.73 L88.91,106.4 L76.49,123.27 Z"/><path d="M50.4,100 L68,91.6 L87.2,100 L68,108.4 Z"/><path d="M40.42,65.6 L76.49,76.73 L88.91,93.6 L68.09,91.27 Z"/><path d="M75.2,57.05 L91.27,68.09 L93.6,88.91 L76.73,76.49 Z"/><circle cx="100" cy="100" r="8"/></svg>
      <span class="font-display text-xl font-bold tracking-tight">Claude Agency</span>
    </a>

    <!-- Desktop -->
    <ul class="hidden items-center gap-7 text-sm sm:flex">
      {links.map((l) => <li><a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined} class={`transition-colors hover:text-ink ${isActive(l.href) ? 'font-medium text-ink' : 'text-muted'}`}>{l.label}</a></li>)}
      <li><a href="https://reporting.claudeagency.fr" target="_blank" rel="noopener" class="transition-colors text-muted hover:text-ink">Admin</a></li>
      <li><a href="/contact/" class="rounded-lg bg-brand-500 px-4 py-2 font-medium text-white transition-colors hover:bg-brand-600">Prendre RDV</a></li>
    </ul>

    <!-- Mobile toggle -->
    <button id="menu-toggle" type="button" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu"
            class="inline-flex h-11 w-11 items-center justify-center rounded-lg text-ink transition-colors hover:bg-cream-100 sm:hidden">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Mobile panel -->
  <div id="mobile-menu" hidden class="border-t border-sand bg-cream-50 sm:hidden">
    <ul class="mx-auto flex max-w-5xl flex-col gap-1 px-4 py-3 text-sm">
      {links.map((l) => <li><a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined} class={`block rounded-md px-3 py-2.5 transition-colors hover:bg-cream-100 ${isActive(l.href) ? 'font-medium text-brand-700' : 'text-ink'}`}>{l.label}</a></li>)}
      <li><a href="https://reporting.claudeagency.fr" target="_blank" rel="noopener" class="block rounded-md px-3 py-2.5 text-ink transition-colors hover:bg-cream-100">Admin</a></li>
      <li><a href="/contact/" class="mt-1 block rounded-lg bg-brand-500 px-4 py-2 text-center font-medium text-white">Prendre RDV</a></li>
    </ul>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', function () {
      var willOpen = menu.hasAttribute('hidden');
      if (willOpen) {
        menu.removeAttribute('hidden');
        btn.setAttribute('aria-expanded', 'true');
        btn.setAttribute('aria-label', 'Fermer le menu');
      } else {
        menu.setAttribute('hidden', '');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', 'Ouvrir le menu');
      }
    });
  })();
</script>
