---
// Calculateur de temps & d'argent gagnés — raisonnement ANNUEL, sans dépendance.
// Chaque tâche : heures/an SANS l'IA, heures/an AVEC l'IA, et € économisés/an.
// Le € est propre à chaque tâche (logique de coût évité, pas un simple heures × taux) :
//   - Qualiopi : accompagnement externe évité (~3 000 € → 2 000 € retenus)
//   - Supports : temps formatrice (~40 €/h)
//   - Admin / relances / conventions : temps assistant·e commercial·e & administratif·ve (~20 €/h)
// Valeurs validées avec Julien — éditables ci-dessous.
const nf = new Intl.NumberFormat('fr-FR');
const fmtRatio = (r) => {
  r = Math.round(r * 10) / 10;
  return Number.isInteger(r) ? String(r) : String(r).replace('.', ',');
};
const tasks = [
  { label: "Tenir à jour mes preuves & indicateurs Qualiopi (toute l'année)", without: 30, withAI: 3, euro: 2000 },
  { label: 'Créer & mettre à jour mes supports de cours', without: 30, withAI: 10, euro: 800 },
  { label: 'Suivi administratif des stagiaires (convocations, attestations, émargements)', without: 180, withAI: 24, euro: 3120 },
  { label: 'Emails & relances (prospects, OPCO, financeurs)', without: 180, withAI: 36, euro: 2880 },
  { label: 'Rédiger conventions, programmes, devis', without: 260, withAI: 87, euro: 3460 },
];
---
<section class="bg-cream-100" aria-labelledby="calc-title">
  <div class="mx-auto max-w-5xl px-4 py-20">
    <h2 id="calc-title" class="font-display text-3xl font-bold text-ink sm:text-4xl">Combien de temps et d'argent l'IA peut vous faire gagner ?</h2>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">Cochez les tâches qui vous concernent. On estime, <strong class="font-semibold text-ink">sur un an</strong>, le temps récupéré et l'argent économisé — on l'affinera ensemble lors de l'audit.</p>

    <div class="mt-10 grid gap-10 md:grid-cols-[1.15fr_0.85fr]">
      <fieldset id="calc-tasks" class="space-y-3 border-0 p-0">
        <legend class="sr-only">Tâches chronophages de votre organisme</legend>
        {tasks.map((t) => (
          <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-sand bg-cream-50 p-4 transition-colors hover:border-brand-300">
            <input type="checkbox" class="calc-task mt-1 h-5 w-5 shrink-0 accent-brand-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500" data-without={t.without} data-with={t.withAI} data-euro={t.euro} />
            <span>
              <span class="block font-medium text-ink">{t.label}</span>
              <span class="mt-1 block text-sm text-muted">Sans l'IA {nf.format(t.without)} h/an → avec l'IA {nf.format(t.withAI)} h/an · ÷{fmtRatio(t.without / t.withAI)} · ~{nf.format(t.euro)} €/an</span>
            </span>
          </label>
        ))}
      </fieldset>

      <div class="md:sticky md:top-24 md:self-start">
        <div class="rounded-2xl border border-sand bg-white p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-brand-600">Votre estimation · sur un an</p>
          <div aria-live="polite">
            <p id="calc-euro" class="mt-3 font-display text-4xl font-extrabold text-ink">—</p>
            <p id="calc-hours" class="mt-1 text-lg text-muted">Cochez vos tâches pour voir l'estimation.</p>
            <p id="calc-detail" class="mt-1 text-sm text-muted"></p>
          </div>
          <p class="mt-4 text-sm text-muted">Estimation indicative, à affiner lors de l'audit.</p>
          <noscript><p class="mt-2 text-sm text-muted">Activez JavaScript pour obtenir l'estimation chiffrée.</p></noscript>
          <a href="/contact/" class="mt-6 inline-block rounded-lg bg-brand-500 px-6 py-3 font-semibold text-white transition-colors hover:bg-brand-600">Valider ce potentiel — audit offert</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var boxes = Array.prototype.slice.call(document.querySelectorAll('.calc-task'));
    var euroEl = document.getElementById('calc-euro');
    var hoursEl = document.getElementById('calc-hours');
    var detailEl = document.getElementById('calc-detail');
    if (!boxes.length || !euroEl || !hoursEl || !detailEl) return;
    var nf = new Intl.NumberFormat('fr-FR');
    function fmtRatio(r) {
      r = Math.round(r * 10) / 10;
      return Number.isInteger(r) ? String(r) : String(r).replace('.', ',');
    }
    function update() {
      var wo = 0, wi = 0, eu = 0, any = false;
      boxes.forEach(function (b) {
        if (b.checked) {
          any = true;
          wo += Number(b.getAttribute('data-without')) || 0;
          wi += Number(b.getAttribute('data-with')) || 0;
          eu += Number(b.getAttribute('data-euro')) || 0;
        }
      });
      if (!any) {
        euroEl.textContent = '—';
        hoursEl.textContent = "Cochez vos tâches pour voir l'estimation.";
        detailEl.textContent = '';
        return;
      }
      var saved = wo - wi;
      var euroR = Math.round(eu / 10) * 10;
      euroEl.textContent = '~ ' + nf.format(euroR) + ' € / an';
      hoursEl.textContent = nf.format(saved) + ' h récupérées / an';
      var ratioTxt = wi > 0 ? ' (÷' + fmtRatio(wo / wi) + ')' : '';
      detailEl.textContent = "Sans l'IA " + nf.format(wo) + " h → avec l'IA " + nf.format(wi) + ' h' + ratioTxt;
      if (window.plausible) window.plausible('Calculator Used');
    }
    boxes.forEach(function (b) { b.addEventListener('change', update); });
  })();
</script>
