---
// Formulaire de diagnostic qualifiant — Web3Forms (même clé/flux que ContactForm).
// Capte rôle + priorité + maturité pour segmenter le lead avant l'audit.
const ACCESS_KEY = '3e5769c5-994f-4c15-8f58-c18cad18c96d';
const roles = [
  "Dirigeant·e d'organisme de formation",
  'Responsable pédagogique',
  'Responsable administratif & qualité',
  'Formateur·rice indépendant·e',
  'Autre',
];
const priorites = [
  'Être plus visible sur Google (SEO / SEA)',
  "Gagner du temps sur l'administratif & Qualiopi",
  'Créer mes supports de cours plus vite',
  'Automatiser le suivi des stagiaires',
  'Je ne sais pas encore — aidez-moi à y voir clair',
];
const maturites = [
  "Je découvre, je m'informe",
  "J'ai des idées, pas encore de projet",
  "J'ai un projet précis",
  'Je veux démarrer rapidement',
];
const fieldCls =
  'mt-1 w-full rounded-lg border border-sand bg-white px-3 py-2 focus:border-brand-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500';
---
<form id="diagnostic-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
  <input type="hidden" name="access_key" value={ACCESS_KEY} />
  <input type="hidden" name="subject" value="Nouveau diagnostic — claudepartners.fr" />
  <input type="hidden" name="redirect" value="https://claudepartners.fr/merci/" />
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

  <div>
    <label for="role" class="block text-sm font-medium">Votre rôle</label>
    <select id="role" name="role" required class={fieldCls}>
      <option value="" disabled selected>Choisissez…</option>
      {roles.map((r) => <option value={r}>{r}</option>)}
    </select>
  </div>

  <div>
    <label for="priorite" class="block text-sm font-medium">Votre priorité n°1</label>
    <select id="priorite" name="priorite" required class={fieldCls}>
      <option value="" disabled selected>Choisissez…</option>
      {priorites.map((p) => <option value={p}>{p}</option>)}
    </select>
  </div>

  <div>
    <label for="maturite" class="block text-sm font-medium">Où en êtes-vous ?</label>
    <select id="maturite" name="maturite" required class={fieldCls}>
      <option value="" disabled selected>Choisissez…</option>
      {maturites.map((m) => <option value={m}>{m}</option>)}
    </select>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="d-name" class="block text-sm font-medium">Nom et prénom</label>
      <input type="text" id="d-name" name="name" required autocomplete="name" class={fieldCls} />
    </div>
    <div>
      <label for="d-organisme" class="block text-sm font-medium">Votre organisme</label>
      <input type="text" id="d-organisme" name="organisme" required autocomplete="organization" class={fieldCls} />
    </div>
  </div>

  <div>
    <label for="d-email" class="block text-sm font-medium">Email professionnel</label>
    <input type="email" id="d-email" name="email" required autocomplete="email" spellcheck="false" class={fieldCls} />
  </div>

  <div>
    <label for="d-message" class="block text-sm font-medium">Un mot sur votre contexte <span class="font-normal text-muted">(optionnel)</span></label>
    <textarea id="d-message" name="message" rows="3" class={fieldCls}></textarea>
  </div>

  <button type="submit" id="diagnostic-submit" class="rounded-lg bg-brand-500 px-5 py-2.5 font-semibold text-white transition-colors hover:bg-brand-600 disabled:cursor-not-allowed disabled:opacity-70">Recevoir mes pistes + audit offert</button>
  <p id="diagnostic-result" class="text-sm" role="status" aria-live="polite"></p>
  <p class="text-xs text-muted">Sans engagement. On ne partage jamais vos informations.</p>
</form>

<script is:inline>
  (function () {
    var form = document.getElementById('diagnostic-form');
    var result = document.getElementById('diagnostic-result');
    var btn = document.getElementById('diagnostic-submit');
    if (!form || !result || !btn) return;
    var btnLabel = btn.textContent;
    var genericError = "Une erreur est survenue. Réessayez ou écrivez-nous à contact@claudepartners.fr.";
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var json = JSON.stringify(Object.fromEntries(new FormData(form)));
      btn.disabled = true; btn.textContent = 'Envoi en cours…';
      result.textContent = 'Envoi en cours…'; result.className = 'text-sm text-muted';
      fetch('https://api.web3forms.com/submit', {
        method: 'POST', headers: { 'Content-Type': 'application/json', Accept: 'application/json' }, body: json,
      }).then(function (res) {
        return res.json().then(function (data) { return { ok: res.status === 200, data: data }; });
      }).then(function (r) {
        if (r.ok) {
          result.textContent = 'Merci ! On revient vers vous très vite avec des pistes concrètes.';
          result.className = 'text-sm text-green-700';
          form.reset();
          if (window.plausible) window.plausible('Diagnostic Submit');
        } else {
          result.textContent = r.data.message || genericError;
          result.className = 'text-sm text-red-700';
        }
      }).catch(function () {
        result.textContent = genericError; result.className = 'text-sm text-red-700';
      }).then(function () {
        btn.disabled = false; btn.textContent = btnLabel;
      });
    });
  })();
</script>
