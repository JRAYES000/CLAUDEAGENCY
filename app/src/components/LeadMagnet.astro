---
// src/components/LeadMagnet.astro
// Bloc CTA + formulaire d'inscription au lead magnet.
// Poste vers la Pages Function /api/subscribe, qui appelle l'API Mailjet côté serveur
// (clé jamais exposée au client). Voir app/functions/api/subscribe.js.
interface Props { variant?: 'compact' | 'full'; }
const { variant = 'compact' } = Astro.props;
const isFull = variant === 'full';
const inputClass =
  'mt-1 w-full rounded-lg border border-sand bg-white px-3 py-2 focus:border-brand-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500';
---
<section
  class={`not-prose rounded-2xl border border-sand bg-cream-100 ${isFull ? 'p-8 sm:p-10' : 'p-6 sm:p-7'}`}
  aria-labelledby="lead-magnet-title"
>
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-600">Ressource gratuite</p>
  <h2 id="lead-magnet-title" class={`mt-2 font-display font-bold text-ink ${isFull ? 'text-3xl sm:text-4xl' : 'text-2xl'}`}>
    {isFull ? 'Recevez le guide gratuitement' : '10 automatisations IA qui libèrent 1 jour/semaine dans un organisme de formation'}
  </h2>
  <p class="mt-3 leading-relaxed text-muted">
    {isFull
      ? 'Indiquez votre email : on vous l’envoie tout de suite, avec quelques conseils pour le mettre en œuvre.'
      : 'Le guide concret, tiré d’un organisme de formation réel : pour chaque tâche, l’automatisation, le temps gagné et l’outil. Recevez-le par email.'}
  </p>

  <form id="lead-magnet-form" action="/api/subscribe" method="POST" class="mt-6 space-y-4">
    <!-- Honeypot anti-bot (doit rester vide) -->
    <input type="text" name="botcheck" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for="lm-firstname" class="block text-sm font-medium">Prénom</label>
        <input type="text" id="lm-firstname" name="firstname" required autocomplete="given-name" class={inputClass} />
      </div>
      <div>
        <label for="lm-email" class="block text-sm font-medium">Email professionnel</label>
        <input type="email" id="lm-email" name="email" required autocomplete="email" spellcheck="false" class={inputClass} />
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for="lm-societe" class="block text-sm font-medium">Organisme <span class="text-muted">(optionnel)</span></label>
        <input type="text" id="lm-societe" name="societe" autocomplete="organization" class={inputClass} />
      </div>
      <div>
        <label for="lm-tel" class="block text-sm font-medium">Téléphone <span class="text-muted">(optionnel)</span></label>
        <input type="tel" id="lm-tel" name="telephone" autocomplete="tel" class={inputClass} />
      </div>
    </div>
    <label class="flex items-start gap-2 text-sm text-muted">
      <input type="checkbox" name="consent" value="1" required class="mt-1" />
      <span>J’accepte de recevoir le guide et des conseils par email. Voir la <a href="/confidentialite/" class="text-brand-600 hover:underline">politique de confidentialité</a>. Désinscription en un clic.</span>
    </label>

    <button type="submit" id="lm-submit" class="rounded-lg bg-brand-500 px-5 py-2.5 font-semibold text-white transition-colors hover:bg-brand-600 disabled:opacity-70">
      Recevoir le guide
    </button>
    <p id="lm-result" class="text-sm" role="status" aria-live="polite"></p>
  </form>
</section>

<script is:inline>
  (function () {
    var form = document.getElementById('lead-magnet-form');
    if (!form) return;
    var btn = document.getElementById('lm-submit');
    var result = document.getElementById('lm-result');
    var label = btn.textContent;
    var genericError = 'Une erreur est survenue. Réessayez ou écrivez-nous à contact@claudeagency.fr.';
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      if (form.botcheck && form.botcheck.value) return; // honeypot rempli => bot
      var data = Object.fromEntries(new FormData(form));
      btn.disabled = true; btn.textContent = 'Envoi en cours…';
      result.textContent = ''; result.className = 'text-sm text-muted';
      try {
        var res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(data),
        });
        var j = await res.json().catch(function () { return {}; });
        if (res.ok && j.ok) {
          if (window.plausible) window.plausible('Lead Magnet Submit');
          // Conversion Google Ads (AW-18240137840) : "Inscription" déclenchée UNIQUEMENT
          // sur une vraie soumission (et plus sur chaque chargement de /merci-ressource/).
          // On attache aussi les données utilisateur pour l'Enhanced Conversions (Google les hache).
          var redirected = false;
          var go = function () {
            if (redirected) return;
            redirected = true;
            window.location.href = '/merci-ressource/';
          };
          if (typeof window.gtag === 'function') {
            try {
              window.gtag('set', 'user_data', {
                email: data.email || undefined,
                phone_number: data.telephone || undefined,
                address: { first_name: data.firstname || undefined },
              });
            } catch (e) {}
            window.gtag('event', 'conversion', {
              send_to: 'AW-18240137840/4mV8CJzVmr8cEPDUyflD',
              value: 1.0,
              currency: 'EUR',
              event_callback: go,
            });
            // Filet de sécurité : on redirige au plus tard après 1,5 s même si le callback ne se déclenche pas.
            setTimeout(go, 1500);
          } else {
            go();
          }
        } else {
          result.textContent = j.error || genericError; result.className = 'text-sm text-red-700';
          btn.disabled = false; btn.textContent = label;
        }
      } catch (err) {
        result.textContent = genericError; result.className = 'text-sm text-red-700';
        btn.disabled = false; btn.textContent = label;
      }
    });
  })();
</script>
